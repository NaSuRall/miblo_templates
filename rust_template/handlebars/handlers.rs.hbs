use crate::config::AppState;
use axum::{Json, extract::State, extract::Path};
use serde_json::{Value, json};
use crate::models::{{ handler_name }};
use crate::models::{{ handler_name_low }}::{{ handler_name }}Option;

pub async fn get_{{ handler_name_low }}(State(state): State<AppState>) -> Json<Value> {
  let res = sqlx::query_file_as!({{ handler_name}}, "{{ sql_path_get }}" )
  .fetch_all(&state.db).await;

  match res {
    Ok(data) => Json(json!({
      "status": "sucess",
      "data": data
    })),
    Err(e) => Json(json!({
        "status": "error ",
        "message": e.to_string()
    }))
  }

}

pub async fn post_{{ handler_name_low }}(State(state): State<AppState>, Json(body): Json<{{ handler_name }}Option> ) -> Json<Value> {

    let res = sqlx::query_file_as!(
    {{ handler_name }}, 
    "{{ sql_path_post }}",
    {{#each fields_name }}
      body.{{ name }}{{#unless @last}},{{/unless}}
    {{/each }}
    ) 
      .execute(&state.db)
      .await;

    match res {
      Ok(_) => Json(json!({
          "status": "success",
        })),
      Err(e) => Json(json!({
          "status": "error",
          "message": e.to_string()
      }))
    }

}

pub async fn patch_{{ handler_name_low }}(State(state): State<AppState>,Path({{ handler_name_low}}_id ): Path<i64>, Json(body): Json<{{ handler_name }}Option> ) -> Json<Value> {

  let res: Result<sqlx::mysql::MySqlQueryResult, sqlx::Error> = sqlx::query_file!(
    "{{ sql_path_patch }}",
    {{#each fields_name }}
      body.{{ name }}{{#unless @last}},{{/unless }}
    {{ /each }},
    {{ handler_name_low}}_id
  )
    .execute(&state.db)
    .await;

  match res {
    Ok(_) => Json(json!({
        "status": "success",
    })),
    Err(e) => Json(json!({
        "status": "error",
        "message": e.to_string()
    }))
  }


}

pub async fn delete_{{ handler_name_low }}(State(state): State<AppState>, Path({{ handler_name_low }}_id ): Path<String> ) -> Json<Value> {

  let res = sqlx::query_file_as!({{ handler_name}}, "{{ sql_path_delete }}", {{ handler_name_low }}_id )
  .execute(&state.db)
  .await;

  match res {
    Ok(_) => Json(json!({
        "status": "sucess",
        "message": " {{ handler_name }} DELETED"
    })),
    Err(e) => Json(json!({
      "status": "error",
      "message": e.to_string()
    }))
  }
}
